plt.figure(figsize=(10,5))
second_dose.plot(kind='bar')

plt.title("Top 10 State- Second Dose Administerd")
plt.xlabel("States")
plt.ylabel("Second Dose")
plt.xticks(rotation=45, ha='right')
plt.tight_layout()
plt.show()

male = pd.to_numeric(df['Male (Doses Administered)'], errors='coerce').max()

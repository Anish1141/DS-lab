import pandas as pd
import seaborn as sns

from sklearn.preprocessing import MinMaxScaler

# Load dataset
df = sns.load_dataset('titanic')

# Display first 5 rows
print("First 5 Rows:\n")
print(df.head())

# Dataset dimensions
print("\nDataset Shape:\n")
print(df.shape)

# Data types
print("\nData Types:\n")
print(df.dtypes)

# Statistical summary
print("\nSummary Statistics:\n")
print(df.describe())


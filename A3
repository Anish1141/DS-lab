import pandas as pd
import seaborn as sns

# Load Iris dataset
df = sns.load_dataset('iris')

# Display first 5 rows
print("First 5 Rows:\n")
print(df.head())

# Overall summary statistics
print("\nOverall Summary Statistics:\n")
print(df.describe())

# Species-wise statistics
print("\nSpecies-wise Summary Statistics:\n")
grouped = df.groupby('species').describe()

print(grouped)
